# Copy this file to .env.local and fill in the values from Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenRouter — used to generate personalized daily habit tasks
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default free model (google/gemma-2-9b-it:free)
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Optional: used as HTTP-Referer header for OpenRouter
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
